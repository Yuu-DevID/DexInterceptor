<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF0D0D1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FF1A1A3E"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DexInterceptor | ..."
            android:textColor="#FF00D4FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="start" />

        <Button
            android:id="@+id/btn_filter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="CONFIG"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:backgroundTint="#4000D4FF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_export"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="EXPORT"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:backgroundTint="#4000FF88"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="CLEAR"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:backgroundTint="#40FF4444"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tv_log_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFB0B0C0"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:textIsSelectable="true"
            android:gravity="bottom"
            android:text="Waiting for intercepted calls...\n" />
    </ScrollView>

</LinearLayout>
